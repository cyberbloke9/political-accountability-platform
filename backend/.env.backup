# ============================================================================
# BACKEND ENVIRONMENT VARIABLES (.env)
# ============================================================================
# This file is for LOCAL DEVELOPMENT and PRODUCTION
# Keep this file SECRET - never commit to Git
# ============================================================================

# ----------------------------------------------------------------------------
# NODE ENVIRONMENT
# ----------------------------------------------------------------------------
# Set to "development" locally, "production" when deployed
NODE_ENV=development

# Server port (Railway/Render auto-set this, 3000 for local dev)
PORT=3000

# ----------------------------------------------------------------------------
# SUPABASE CONFIGURATION (REQUIRED)
# ----------------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Your Supabase project URL
# Format: https://xxxxxxxxxxxxx.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase SERVICE ROLE key (KEEP SECRET - has admin privileges)
# This is a long JWT token starting with "eyJ..."
# WARNING: This key bypasses Row Level Security - NEVER expose in frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlvdXItcHJvamVjdC1yZWYiLCJyb2xlIjoic2VydmljZV9yb2xlIiwiaWF0IjoxNjE2MjM5MDIyLCJleHAiOjE5MzE4MTUwMjJ9.your-service-role-key-here

# Your Supabase anonymous/public key (for client-side operations in backend)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlvdXItcHJvamVjdC1yZWYiLCJyb2xlIjoiYW5vbiIsImlhdCI6MTYxNjIzOTAyMiwiZXhwIjoxOTMxODE1MDIyfQ.your-anon-key-here

# ----------------------------------------------------------------------------
# DATABASE CONNECTION (REQUIRED)
# ----------------------------------------------------------------------------
# Get this from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/database
# Click "Connection String" → "URI" → Copy

# Direct PostgreSQL connection (for Prisma)
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-database-password@db.your-project-ref.supabase.co:5432/postgres

# Connection pooling URL (optional, for production with many connections)
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true
# DATABASE_URL_POOLED=postgresql://postgres:your-database-password@db.your-project-ref.supabase.co:6543/postgres?pgbouncer=true

# ----------------------------------------------------------------------------
# CORS CONFIGURATION (REQUIRED)
# ----------------------------------------------------------------------------
# Your frontend URL (for CORS headers)
# Local dev: http://localhost:3000
# Production: https://your-app-name.vercel.app
CORS_ORIGIN=http://localhost:3000

# For multiple origins (comma-separated):
# CORS_ORIGIN=http://localhost:3000,https://your-app-name.vercel.app,https://your-custom-domain.com

# ----------------------------------------------------------------------------
# EXTERNAL APIs - FRAUD DETECTION (REQUIRED FOR FRAUD DETECTION)
# ----------------------------------------------------------------------------

# Google Cloud Vision API (for reverse image search fraud detection)
# Get key: https://console.cloud.google.com/apis/credentials
# 1. Create project
# 2. Enable "Cloud Vision API"
# 3. Create credentials → API Key
GOOGLE_VISION_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Google Cloud Project ID (from Google Cloud Console)
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# Alternative: Use service account JSON file (more secure)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ----------------------------------------------------------------------------
# EMAIL SERVICE (OPTIONAL - Supabase has built-in email)
# ----------------------------------------------------------------------------
# SendGrid (for custom transactional emails)
# Sign up: https://sendgrid.com (free tier: 100 emails/day)
# Get key: Settings → API Keys → Create API Key
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com
# SENDGRID_FROM_NAME=Political Accountability Platform

# Note: Supabase Auth sends verification emails automatically
# You only need SendGrid for custom emails (notifications, newsletters, etc.)

# ----------------------------------------------------------------------------
# RATE LIMITING (OPTIONAL - defaults provided)
# ----------------------------------------------------------------------------
# General API rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Authentication endpoints rate limiting (stricter)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# Verification submission rate limiting
VERIFICATION_RATE_LIMIT_WINDOW_MS=3600000
VERIFICATION_RATE_LIMIT_MAX_REQUESTS=10

# ----------------------------------------------------------------------------
# OPTIONAL: ERROR TRACKING & MONITORING
# ----------------------------------------------------------------------------
# Sentry (error tracking)
# Sign up: https://sentry.io (free tier: 5K errors/month)
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxxx

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# OPTIONAL: FEATURE FLAGS
# ----------------------------------------------------------------------------
# Enable/disable features
ENABLE_FRAUD_DETECTION=true
ENABLE_MFA=true
ENABLE_OAUTH=false
ENABLE_EMAIL_NOTIFICATIONS=false

# ----------------------------------------------------------------------------
# OPTIONAL: CITIZEN SCORING
# ----------------------------------------------------------------------------
# Materialized view refresh interval (in minutes)
SCORE_REFRESH_INTERVAL=10

# Minimum reputation for privileges
MIN_REPUTATION_FOR_MFA_REQUIRED=1000
MIN_REPUTATION_FOR_CHAMPION_STATUS=5000

# ----------------------------------------------------------------------------
# OPTIONAL: STORAGE LIMITS
# ----------------------------------------------------------------------------
# Max file sizes (in bytes)
MAX_IMAGE_SIZE_BYTES=5242880
MAX_VIDEO_SIZE_BYTES=52428800

# Max files per verification
MAX_IMAGES_PER_VERIFICATION=5
MAX_VIDEOS_PER_VERIFICATION=1

# Storage quota per user (in bytes)
USER_STORAGE_QUOTA_BYTES=104857600

# ============================================================================
# QUICK START INSTRUCTIONS
# ============================================================================
#
# STEP 1: Create Supabase Project
# --------------------------------
# 1. Go to: https://supabase.com/dashboard
# 2. Click "New Project"
# 3. Name: "political-accountability-platform"
# 4. Database Password: [create strong password - SAVE IT!]
# 5. Region: Choose closest to your users (Singapore for India)
# 6. Click "Create new project" (takes ~2 minutes)
#
# STEP 2: Get Supabase Credentials
# ---------------------------------
# 1. Go to: Settings → API
# 2. Copy these values:
#    - Project URL → SUPABASE_URL
#    - anon public key → SUPABASE_ANON_KEY
#    - service_role key → SUPABASE_SERVICE_ROLE_KEY (KEEP SECRET!)
#
# 3. Go to: Settings → Database → Connection String → URI
# 4. Copy the connection string → DATABASE_URL
#    (Replace [YOUR-PASSWORD] with your database password from Step 1)
#
# STEP 3: Set Up Google Vision API (for fraud detection)
# -------------------------------------------------------
# 1. Go to: https://console.cloud.google.com
# 2. Create new project or select existing
# 3. Enable "Cloud Vision API"
# 4. Go to: APIs & Services → Credentials
# 5. Click "Create Credentials" → "API Key"
# 6. Copy API key → GOOGLE_VISION_API_KEY
# 7. Copy Project ID → GOOGLE_CLOUD_PROJECT_ID
#
# STEP 4: Update CORS_ORIGIN
# ---------------------------
# - For local dev: http://localhost:3000
# - For production: https://your-app-name.vercel.app
#
# STEP 5: Save and Test
# ----------------------
# 1. Save this file
# 2. Run: npm install
# 3. Run: npm run dev
# 4. Backend should start on http://localhost:3000
#
# ============================================================================

# ============================================================================
# FOR PRODUCTION DEPLOYMENT
# ============================================================================
#
# If deploying backend to Railway/Render/Heroku:
# 1. Add all these environment variables in the platform's dashboard
# 2. Change NODE_ENV=production
# 3. Update CORS_ORIGIN to your Vercel frontend URL
# 4. Ensure DATABASE_URL uses production Supabase connection string
#
# IMPORTANT: Use environment variable manager in deployment platform
# DO NOT commit this .env file to Git
#
# ============================================================================

# ============================================================================
# SECURITY CHECKLIST
# ============================================================================
# ✅ DATABASE_URL contains production database password
# ✅ SUPABASE_SERVICE_ROLE_KEY is kept secret (not in frontend)
# ✅ GOOGLE_VISION_API_KEY is restricted to backend only
# ✅ CORS_ORIGIN matches your frontend domain exactly
# ✅ This .env file is in .gitignore (never committed)
# ✅ All secrets are unique and not default values
# ✅ Production secrets are different from development secrets
# ============================================================================

# ============================================================================
# TROUBLESHOOTING
# ============================================================================
#
# Error: "Invalid JWT"
# → Check SUPABASE_SERVICE_ROLE_KEY is copied correctly (full token)
#
# Error: "Connection refused"
# → Check DATABASE_URL has correct password and project ref
#
# Error: "CORS error"
# → Update CORS_ORIGIN to match your frontend URL exactly
#
# Error: "Vision API quota exceeded"
# → Check GOOGLE_VISION_API_KEY is valid
# → Ensure billing is enabled in Google Cloud Console
#
# ============================================================================

# ============================================================================
# OPTIONAL: USING SERVICE ACCOUNT FOR GOOGLE APIS (More Secure)
# ============================================================================
# Instead of API key, you can use a service account JSON file:
#
# 1. In Google Cloud Console: IAM & Admin → Service Accounts
# 2. Create Service Account
# 3. Grant "Cloud Vision API User" role
# 4. Create Key → JSON
# 5. Download JSON file to your project (e.g., /config/gcp-service-account.json)
# 6. Set path:
#    GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-service-account.json
# 7. Comment out GOOGLE_VISION_API_KEY
#
# ============================================================================
